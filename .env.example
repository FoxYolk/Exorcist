# copy this to .env and fill it in
DISCORD_TOKEN=your-bot-token-here

# where the per server settings live, leave it as is unless you want it elsewhere
EXORCIST_CONFIG=config.json

# only needed if tesseract isn't on your PATH (mostly a windows thing)
# example: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
